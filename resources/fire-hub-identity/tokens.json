{
  "$meta": {
    "name": "FAO Fire Hub — Visual Identity Tokens",
    "description": "Machine-readable design tokens for the FAO Global Fire Management Hub. Mirrors the CSS custom properties in css/tokens/. Hex values are authoritative.",
    "font": "Lato (FAO institutional typeface, loaded from Google Fonts)"
  },
  "color": {
    "brand": {
      "petrol": "#0c4b66",
      "petrolBlue": "#2f7a9a",
      "sky": "#5dacbd",
      "aqua": "#aae2e3",
      "rust": "#a6361e",
      "flameRed": "#ef371f",
      "flameOrange": "#f36617",
      "orange": "#f67d14",
      "gold": "#f8af0b",
      "pine": "#1f6e43",
      "forest": "#2a8559",
      "sage": "#69a078",
      "faoBlue": "#0076b6",
      "white": "#ffffff"
    },
    "neutral": {
      "ink": "#11323f",
      "graphite": "#34505a",
      "slate": "#5a727b",
      "mist": "#8aa0a6",
      "line": "#d7e0e2",
      "cloud": "#eef3f4",
      "canvas": "#f6f9f9",
      "paper": "#ffffff"
    },
    "text": {
      "strong": "#11323f",
      "body": "#34505a",
      "muted": "#5a727b",
      "faint": "#8aa0a6",
      "heading": "#a6361e",
      "inverse": "#ffffff",
      "link": "#2f7a9a"
    },
    "surface": {
      "page": "#f6f9f9",
      "card": "#ffffff",
      "sunken": "#eef3f4",
      "dark": "#0c4b66",
      "dark2": "#0a3f57",
      "brand": "#2f7a9a"
    },
    "border": {
      "subtle": "#d7e0e2",
      "default": "#c4d0d3",
      "strong": "#34505a",
      "onDark": "rgba(255,255,255,0.22)"
    },
    "accent": {
      "base": "#f67d14",
      "hot": "#f36617",
      "press": "#d95f0a"
    },
    "status": {
      "success": "#2a8559",
      "warning": "#f8af0b",
      "danger": "#ef371f",
      "info": "#2f7a9a",
      "successSoft": "#e3f0e9",
      "warningSoft": "#fdf0d2",
      "dangerSoft": "#fbe0db",
      "infoSoft": "#e0edf2"
    }
  },
  "typography": {
    "family": {
      "sans": "'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif",
      "display": "'Lato', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif",
      "mono": "ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, monospace"
    },
    "weight": { "light": 300, "regular": 400, "bold": 700, "black": 900 },
    "size": {
      "display": "64px", "h1": "44px", "h2": "34px", "h3": "26px", "h4": "20px",
      "lead": "19px", "bodyLg": "18px", "body": "16px", "sm": "14px", "xs": "12px", "overline": "12px"
    },
    "leading": { "tight": 1.08, "snug": 1.2, "normal": 1.45, "relaxed": 1.6 },
    "tracking": {
      "display": "-0.01em", "tight": "-0.005em", "normal": "0", "wide": "0.04em", "overline": "0.14em"
    }
  },
  "spacing": {
    "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px",
    "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px",
    "20": "80px", "24": "96px", "32": "128px"
  },
  "container": { "sm": "640px", "md": "880px", "lg": "1120px", "xl": "1320px" },
  "radius": {
    "none": "0", "sm": "4px", "md": "8px", "lg": "12px", "xl": "16px", "pill": "999px"
  },
  "border": { "hair": "1px", "thick": "2px", "accent": "4px" },
  "shadow": {
    "xs": "0 1px 2px rgba(17,50,63,0.06)",
    "sm": "0 1px 3px rgba(17,50,63,0.08), 0 1px 2px rgba(17,50,63,0.06)",
    "md": "0 4px 12px rgba(17,50,63,0.10), 0 2px 4px rgba(17,50,63,0.06)",
    "lg": "0 12px 32px rgba(17,50,63,0.14), 0 4px 8px rgba(17,50,63,0.08)",
    "focusRing": "0 0 0 3px rgba(47,122,154,0.45)"
  },
  "motion": {
    "easeStandard": "cubic-bezier(0.2, 0, 0, 1)",
    "easeOut": "cubic-bezier(0.16, 1, 0.3, 1)",
    "durationFast": "120ms",
    "durationBase": "200ms",
    "durationSlow": "320ms"
  }
}
